# ---------------------------------------------------------------------------
# Auth (NextAuth / Auth.js v5)
# ---------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# GitHub OAuth App — create at https://github.com/settings/developers
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
# (and the production URL once deployed)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
# Comma-separated list of emails allowed to sign in
ADMIN_ALLOWED_EMAILS=manubown@gmail.com

# ---------------------------------------------------------------------------
# Vercel — https://vercel.com/account/tokens
# ---------------------------------------------------------------------------
VERCEL_TOKEN=
# Optional: scope to a team. Leave blank for personal account.
VERCEL_TEAM_ID=

# ---------------------------------------------------------------------------
# Supabase Management API — https://supabase.com/dashboard/account/tokens
# Used to list projects, read project status, run health checks.
# ---------------------------------------------------------------------------
SUPABASE_ACCESS_TOKEN=

# ---------------------------------------------------------------------------
# Per-project service-role keys (optional — only set for projects whose
# tables/row counts you want surfaced on the dashboard)
# Format: SUPABASE_SERVICE_ROLE_<SLUG_UPPER>
# ---------------------------------------------------------------------------
# SUPABASE_SERVICE_ROLE_GRAETZL=
